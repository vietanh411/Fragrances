# ─────────────────────────────────────────────────────────────────────────────
# VA Decants — environment variables
# Copy this file to ".env.local" for local development, and set the same three
# values in Vercel → Project → Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# Your Google Sheet's ID and the tab's gid (both are in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit?gid=<SHEET_GID>)
# The sheet must be shared "Anyone with the link → Viewer" (or Published to web).
SHEET_ID=1vrymjukHfJ6V2czy5FVGAM5-edoC7n_DP2LpWwudfDE
SHEET_GID=557117222

# Web3Forms access key — get a free one at https://web3forms.com (enter the email
# where you want orders delivered; the key arrives by email). This is a PUBLIC
# key (safe to expose in the browser); it only lets the form email YOU.
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
